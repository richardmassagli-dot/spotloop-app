# ─── Supabase (required for production / real data) ───────────────
# Create project: https://supabase.com → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Run SQL from supabase/schema.sql in Supabase SQL Editor before first use.
# Migration 004_bootstrap_dev.sql + deine E-Mail:
#   insert into public.app_bootstrap_emails (email) values ('deine@email.de');

# Test-Admin: Admin-Rechte + Spot sofort freischalten (Button in App)
VITE_ENABLE_DEV_BOOTSTRAP=false

# Optional: Migrationen automatisch (npm run migrate:pending)
# SUPABASE_ACCESS_TOKEN=   # supabase.com/dashboard/account/tokens
# SUPABASE_DB_PASSWORD=    # Settings → Database → password

# ─── Optional: Firebase (legacy, not used by current app code) ────
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
